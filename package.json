{
    "name": "invoice-analyzer-app",
    "version": "1.0.0",
    "description": "Local invoice analyzer using gemini-3-flash-preview Vision API",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc --build",
        "build:backend": "tsc -p tsconfig.backend.json",
        "build:frontend": "tsc -p tsconfig.frontend.json",
        "start": "node dist/server.js",
        "dev": "tsx watch server.ts",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write '**/*.{ts,json,md,css,html}'",
        "format:check": "prettier --check '**/*.{ts,json,md,css,html}'",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --build --noEmit",
        "knip": "knip"
    },
    "jest": {
        "testEnvironment": "node",
        "transform": {
            "^.+\\.ts$": [
                "ts-jest",
                {
                    "useESM": false,
                    "tsconfig": "tsconfig.test.json",
                    "diagnostics": {
                        "ignoreCodes": [151002]
                    }
                }
            ],
            "node_modules/(p-limit|yocto-queue)/.+\\.js$": [
                "ts-jest",
                {
                    "useESM": false,
                    "diagnostics": false
                }
            ]
        },
        "testMatch": [
            "**/tests/**/*.test.ts"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/.claude/"
        ],
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "transformIgnorePatterns": [
            "node_modules/(?!(p-limit|yocto-queue)/)"
        ],
        "coveragePathIgnorePatterns": [
            "/node_modules/",
            "/public/",
            "/dist/"
        ]
    },
    "keywords": [
        "invoice",
        "pdf",
        "gemini",
        "ocr"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "express-rate-limit": "^8.2.1",
        "p-limit": "^7.2.0",
        "pdf-lib": "^1.17.1",
        "sanitize-filename": "^1.6.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.4.0",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.3.0",
        "jest": "^30.2.0",
        "knip": "^5.84.1",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    }
}
