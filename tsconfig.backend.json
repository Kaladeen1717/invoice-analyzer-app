{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true,
        "composite": true
    },
    "include": ["src/**/*.ts", "server.ts", "batch-process.ts", "scripts/**/*.ts"],
    "exclude": ["src/frontend/**"]
}
